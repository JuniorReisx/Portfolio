---
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "#home",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M21 20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.48907C3 9.18048 3.14247 8.88917 3.38606 8.69972L11.3861 2.47749C11.7472 2.19663 12.2528 2.19663 12.6139 2.47749L20.6139 8.69972C20.8575 8.88917 21 9.18048 21 9.48907V20ZM19 19V9.97815L12 4.53371L5 9.97815V19H19Z"></path></svg>`,
  },
  {
    label: "Projects",
    href: "#projects",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M4 5V19H20V7H11.5858L9.58579 5H4ZM12.4142 5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3H10.4142L12.4142 5Z"></path></svg>`,
  },
  {
    label: "Experience",
    href: "#experience",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M7 5V2C7 1.44772 7.44772 1 8 1H16C16.5523 1 17 1.44772 17 2V5H21C21.5523 5 22 5.44772 22 6V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V6C2 5.44772 2.44772 5 3 5H7ZM4 16V19H20V16H4ZM4 14H20V7H4V14ZM9 3V5H15V3H9Z"></path></svg>`,
  },
  {
    label: "Contact",
    href: "#contact",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M21.7267 2.95694L16.2734 22.0432C16.1225 22.5716 15.7979 22.5956 15.5563 22.1126L11 13L1.9229 9.36919C1.41322 9.16532 1.41953 8.86022 1.95695 8.68108L21.0432 2.31901C21.5716 2.14285 21.8747 2.43866 21.7267 2.95694ZM19.0353 5.09647L6.81221 9.17085L12.4488 11.4255L15.4895 17.5068L19.0353 5.09647Z"></path></svg>`,
  },
];

const NAV_HEIGHT_DESKTOP = 72;
const NAV_HEIGHT_MOBILE = 72;
---

<nav id="main-nav" class="main-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="#home" class="nav-brand" data-nav-link aria-label="Junior Reis — Home">
      <span class="nav-brand-mark">JR</span>
      <span class="nav-brand-name">Junior Reis</span>
    </a>

    <ul class="nav-list" role="list">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link" data-nav-link>
              <span class="nav-link-icon" set:html={item.icon} />
              <span class="nav-link-label">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  :global(body) {
    padding-bottom: var(--nav-offset-mobile, 0px);
  }

  @media (max-width: 767px) {
    :global(body) {
      --nav-offset-mobile: 76px;
    }
  }

  .main-nav {
    position: fixed;
    z-index: 100;
    left: 50%;
    transform: translateX(-50%);
    width: min(92vw, 720px);
    bottom: 0.75rem;
    padding: 0 0.5rem;
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .main-nav {
      top: 1.25rem;
      bottom: auto;
      width: min(90vw, 860px);
    }
  }

  .nav-inner {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.5rem 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--background) 88%, transparent);
    border: 1px solid transparent;
    border-radius: 1rem;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      border-radius 0.25s ease,
      box-shadow 0.25s ease;
  }

  @media (min-width: 768px) {
    .nav-inner {
      padding: 0.5rem 0.75rem;
      border-radius: 9999px;
    }
  }

  .main-nav.is-scrolled .nav-inner {
    background: var(--component-bg);
    border-color: #ffffff14;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .nav-brand {
    display: none;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--white);
    flex-shrink: 0;
    padding: 0.35rem 0.5rem 0.35rem 0.25rem;
    border-radius: 9999px;
    transition: opacity 0.2s ease;
  }

  @media (min-width: 768px) {
    .nav-brand {
      display: flex;
    }
  }

  .nav-brand:hover {
    opacity: 0.85;
  }

  .nav-brand-mark {
    width: 2rem;
    height: 2rem;
    border-radius: 0.6rem;
    background: linear-gradient(135deg, var(--sec), var(--sec-dim));
    color: var(--background);
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Syne", sans-serif;
  }

  .nav-brand-name {
    font-family: "Syne", sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex: 1;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .nav-list {
      justify-content: center;
      flex: 1;
      gap: 0.25rem;
    }
  }

  .nav-link {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    min-width: 3.5rem;
    padding: 0.5rem 0.65rem;
    text-decoration: none;
    color: var(--white-icon);
    font-size: 0.65rem;
    font-weight: 500;
    border-radius: 0.75rem;
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  @media (min-width: 768px) {
    .nav-link {
      flex-direction: row;
      gap: 0;
      min-width: auto;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      border-radius: 9999px;
    }
  }

  .nav-link:hover {
    color: var(--white);
    background: #ffffff08;
  }

  .nav-link.is-active {
    color: var(--white);
    background: #ffffff10;
  }

  @media (min-width: 768px) {
    .nav-link.is-active {
      background: color-mix(in srgb, var(--sec) 18%, transparent);
      color: var(--white);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sec) 35%, transparent);
    }
  }

  .nav-link-icon {
    display: flex;
    line-height: 0;
  }

  @media (min-width: 768px) {
    .nav-link-icon {
      display: none;
    }
  }

  .nav-link-label {
    line-height: 1.1;
    white-space: nowrap;
  }
</style>

<script define:vars={{ NAV_HEIGHT_DESKTOP, NAV_HEIGHT_MOBILE }}>
  const nav = document.getElementById("main-nav");
  const navLinks = document.querySelectorAll("[data-nav-link]");
  const sectionIds = ["home", "projects", "experience", "contact"];
  const isMobile = () => window.matchMedia("(max-width: 767px)").matches;
  const navOffset = () => (isMobile() ? NAV_HEIGHT_MOBILE : NAV_HEIGHT_DESKTOP) + 16;

  function setActiveSection(id) {
    navLinks.forEach((link) => {
      const href = link.getAttribute("href");
      const match = href === `#${id}`;
      link.classList.toggle("is-active", match);
    });
  }

  function updateScrollState() {
    nav?.classList.toggle("is-scrolled", window.scrollY > 8);
  }

  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (!el) return;
    const top = el.getBoundingClientRect().top + window.scrollY - navOffset();
    window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
  }

  navLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href?.startsWith("#")) return;
      e.preventDefault();
      const id = href.slice(1);
      setActiveSection(id);
      scrollToSection(id);
      history.replaceState(null, "", href);
    });
  });

  window.addEventListener("scroll", () => {
    updateScrollState();
    updateActiveFromScroll();
  }, { passive: true });

  let scrollRaf = 0;
  function updateActiveFromScroll() {
    if (scrollRaf) return;
    scrollRaf = requestAnimationFrame(() => {
      scrollRaf = 0;
      const offset = navOffset();
      let currentId = sectionIds[0];

      for (const id of sectionIds) {
        const el = document.getElementById(id);
        if (!el) continue;
        const top = el.getBoundingClientRect().top;
        if (top - offset <= 24) {
          currentId = id;
        }
      }

      setActiveSection(currentId);
    });
  }

  updateScrollState();
  updateActiveFromScroll();

  window.addEventListener("resize", updateActiveFromScroll, { passive: true });
</script>
