---
import SectionHeader from "./SectionHeader.astro";

const contacts = [
  {
    label: "Location",
    value: "Salvador, Bahia — Brazil",
    href: null,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    stroke: true,
  },
  {
    label: "WhatsApp",
    value: "+55 71 99913-6601",
    href: "https://wa.me/5571999136601",
    icon: `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>`,
    stroke: false,
  },
  {
    label: "Email",
    value: "gilmaikjunior2@gmail.com",
    href: "mailto:gilmaikjunior2@gmail.com",
    copy: "gilmaikjunior2@gmail.com",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
    stroke: true,
  },
  {
    label: "LinkedIn",
    value: "gil-maik-junior",
    href: "https://www.linkedin.com/in/gil-maik-junior/",
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
    stroke: false,
  },
];
---

<section id="contact" class="w-full py-20 md:py-28 border-t border-[#ffffff08]">
  <div class="max-w-5xl mx-auto">
    <SectionHeader
      eyebrow="Contact"
      title="Ready for your next hire?"
      description="Recruiters: I typically reply within 24 hours. Prefer email or LinkedIn for formal processes — WhatsApp for a quick intro."
    />

    <div class="reveal-on-scroll grid grid-cols-1 lg:grid-cols-5 gap-8">
      <!-- CTA card -->
      <div class="lg:col-span-2 relative overflow-hidden rounded-2xl border border-[var(--sec)]/30 p-8 md:p-10 bg-gradient-to-br from-[var(--sec)]/15 via-[#ffffff05] to-transparent">
        <div class="absolute -top-20 -right-20 w-48 h-48 bg-[var(--sec)]/20 rounded-full blur-3xl"></div>
        <h3 class="text-2xl font-bold text-[var(--white)] relative">Let's build something impactful.</h3>
        <p class="mt-4 text-[var(--white-icon)] leading-relaxed relative">
          Fullstack · Spring Boot · React · DevOps basics · Available for remote or hybrid in Brazil.
        </p>
        <div class="mt-8 flex flex-col gap-3 relative">
          <a href="mailto:gilmaikjunior2@gmail.com?subject=Interview%20%E2%80%94%20Junior%20Reis" class="btn-primary justify-center">
            Schedule via email
          </a>
          <a href="https://wa.me/5571999136601" target="_blank" rel="noopener noreferrer" class="btn-secondary justify-center">
            Message on WhatsApp
          </a>
        </div>
      </div>

      <!-- Contact list -->
      <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
        {
          contacts.map((item) => {
            const Tag = item.href ? "a" : "div";
            return (
              <Tag
                href={item.href ?? undefined}
                target={item.href?.startsWith("http") ? "_blank" : undefined}
                rel={item.href?.startsWith("http") ? "noopener noreferrer" : undefined}
                class={`contact-tile glass-card rounded-2xl p-6 transition-all duration-300 ${item.href ? "hover:border-[var(--sec)]/40 hover:-translate-y-1 cursor-pointer group" : ""}`}
                data-copy={item.copy}
              >
                <svg
                  class="w-7 h-7 text-[var(--sec)] mb-4"
                  fill={item.stroke ? "none" : "currentColor"}
                  stroke={item.stroke ? "currentColor" : undefined}
                  viewBox="0 0 24 24"
                  set:html={item.icon}
                />
                <p class="text-xs uppercase tracking-wider text-[var(--white-icon)]">{item.label}</p>
                <p class="mt-1 text-lg font-semibold text-[var(--white)] group-hover:text-[var(--sec)] transition-colors break-all">
                  {item.value}
                </p>
                {item.copy && (
                  <button
                    type="button"
                    class="copy-btn mt-3 text-xs font-medium text-[var(--sec)] hover:underline"
                    data-copy={item.copy}
                  >
                    Copy email
                  </button>
                )}
              </Tag>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const text = (e.currentTarget as HTMLButtonElement).dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const el = e.currentTarget as HTMLButtonElement;
      const prev = el.textContent;
      el.textContent = "Copied!";
      setTimeout(() => { el.textContent = prev; }, 2000);
    });
  });
</script>
