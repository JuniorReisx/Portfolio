---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import sihs from "../../public/sihs.png";
import paraguacu from "../../public/paraguacu.jpg";
import type { ImageMetadata } from "astro";

interface Experience {
  company: string;
  companyShort: string;
  role: string;
  period: string;
  type: string;
  description: string;
  highlights: string[];
  technologies: string[];
  logo: ImageMetadata | string;
  isImage: boolean;
}

const experiences: Experience[] = [
  {
    company: "Secretaria de Infraestrutura Hídrica e Saneamento",
    companyShort: "SIHS · Governo da Bahia",
    role: "Desenvolvedor Fullstack",
    period: "2025 — Atual",
    type: "Tempo integral",
    description:
      "Desenvolvimento de sistemas internos que automatizam processos críticos, reduzem trabalho manual e dão visibilidade operacional para equipes de campo e gestão.",
    highlights: [
      "Sistema de reuniões com autenticação LDAP e painel administrativo",
      "APIs REST integradas a PostgreSQL e fluxos de aprovação",
      "Interfaces React com foco em usabilidade para usuários não técnicos",
    ],
    technologies: [
      "TypeScript",
      "React",
      "Node.js",
      "Express",
      "PostgreSQL",
      "LDAP",
      "Tailwind CSS",
      "Git",
      "CI/CD",
    ],
    logo: sihs as ImageMetadata,
    isImage: true,
  },
  {
    company: "Paraguaçu Engenharia",
    companyShort: "Paraguaçu Engenharia",
    role: "Analista de Suporte Técnico",
    period: "2024 — 2025",
    type: "Tempo integral",
    description:
      "Atuação em ambiente corporativo com foco em estabilidade de infraestrutura, resolução de incidentes e suporte a usuários em escala.",
    highlights: [
      "Monitoramento de servidores Windows e redes corporativas",
      "Gestão de tickets e SLA em ambiente L1/L2",
      "Manutenção de Active Directory, hardware e estações de trabalho",
    ],
    technologies: [
      "Windows Server",
      "Active Directory",
      "Redes",
      "Helpdesk",
      "Monitoramento",
      "Troubleshooting",
    ],
    logo: paraguacu as ImageMetadata,
    isImage: true,
  },
  {
    company: "Projetos independentes",
    companyShort: "Freelancer",
    role: "Desenvolvedor Fullstack",
    period: "2022 — Atual",
    type: "Projetos sob demanda",
    description:
      "Entrega ponta a ponta de sites e aplicações web para clientes — do protótipo ao deploy, com performance, SEO e código maintível.",
    highlights: [
      "Landing pages e dashboards com React e Tailwind",
      "Integração de pagamentos, APIs e bancos relacionais",
      "Deploy contínuo na Vercel com pipelines enxutos",
    ],
    technologies: [
      "React",
      "TypeScript",
      "Node.js",
      "PostgreSQL",
      "Vite",
      "Figma",
      "Vercel",
      "SEO",
    ],
    logo: "⚡",
    isImage: false,
  },
];
---

<section id="experience" class="w-full py-20 md:py-28 relative overflow-hidden border-t border-[#ffffff08]">
  <div class="max-w-5xl mx-auto">
    <SectionHeader
      eyebrow="Carreira"
      title="Experiências que constroem o meu stack"
      description="Do setor público ao freelance — sempre com entrega real, código em produção e impacto mensurável."
      align="center"
    />

    <div class="experience-list space-y-6 md:space-y-8">
      {
        experiences.map((exp, index) => (
          <article
            class="reveal-on-scroll exp-card group"
            style={`transition-delay: ${index * 0.08}s`}
          >
            <div class="exp-card-glow" aria-hidden="true"></div>

            <div class="exp-card-inner">
              <header class="exp-card-header">
                <div class="exp-logo-wrap">
                  {exp.isImage ? (
                    <Image
                      src={exp.logo as ImageMetadata}
                      alt={exp.company}
                      class="exp-logo-img"
                      width={80}
                      height={80}
                    />
                  ) : (
                    <span class="exp-logo-emoji">{exp.logo}</span>
                  )}
                </div>

                <div class="exp-header-text">
                  <div class="exp-meta-row">
                    <span class="exp-role-badge">{exp.role}</span>
                    <span class="exp-type-chip">{exp.type}</span>
                  </div>
                  <h3 class="exp-company">{exp.companyShort}</h3>
                  <p class="exp-company-full">{exp.company}</p>
                  <time class="exp-period" datetime={exp.period.replace(" — ", "/")}>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="exp-period-icon" aria-hidden="true">
                      <path d="M12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12C22 17.5228 17.5228 22 12 22ZM12 20C16.4183 20 20 16.4183 20 12C20 7.58172 16.4183 4 12 4C7.58172 4 4 7.58172 4 12C4 16.4183 7.58172 20 12 20ZM13 12H17V14H11V7H13V12Z"/>
                    </svg>
                    {exp.period}
                  </time>
                </div>
              </header>

              <p class="exp-description">{exp.description}</p>

              <ul class="exp-highlights">
                {exp.highlights.map((item) => (
                  <li>
                    <span class="exp-highlight-dot" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>

              <div class="exp-tech">
                {exp.technologies.map((tech) => (
                  <span class="exp-tech-tag">{tech}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .experience-list {
    position: relative;
  }

  .exp-card {
    position: relative;
    border-radius: 1.25rem;
  }

  .exp-card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--sec) 40%, transparent),
      transparent 45%,
      color-mix(in srgb, var(--sec) 15%, transparent)
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .exp-card:hover .exp-card-glow,
  .exp-card:focus-within .exp-card-glow {
    opacity: 1;
  }

  .exp-card-inner {
    position: relative;
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: linear-gradient(145deg, #ffffff0c 0%, #ffffff03 55%, #ffffff01 100%);
    border: 1px solid #ffffff12;
    backdrop-filter: blur(12px);
    transition:
      border-color 0.35s ease,
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s ease;
  }

  @media (min-width: 768px) {
    .exp-card-inner {
      padding: 2rem 2.25rem;
    }
  }

  .exp-card:hover .exp-card-inner {
    border-color: color-mix(in srgb, var(--sec) 35%, transparent);
    transform: translateY(-4px);
    box-shadow:
      0 20px 50px rgba(0, 0, 0, 0.35),
      0 0 0 1px color-mix(in srgb, var(--sec) 12%, transparent);
  }

  .exp-card-header {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  .exp-logo-wrap {
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #ffffff18;
    background: linear-gradient(145deg, #ffffff12, #ffffff04);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    transition: transform 0.35s ease;
  }

  .exp-card:hover .exp-logo-wrap {
    transform: scale(1.05);
  }

  .exp-logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .exp-logo-emoji {
    font-size: 1.75rem;
    line-height: 1;
  }

  .exp-header-text {
    flex: 1;
    min-width: 0;
  }

  .exp-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .exp-role-badge {
    display: inline-flex;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--background);
    background: linear-gradient(135deg, var(--sec), #c9a8ff);
    border-radius: 9999px;
    box-shadow: 0 2px 12px var(--glow);
  }

  .exp-type-chip {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--white-icon);
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    border: 1px solid #ffffff14;
    background: #ffffff06;
  }

  .exp-company {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 0.2rem;
  }

  @media (min-width: 768px) {
    .exp-company {
      font-size: 1.5rem;
    }
  }

  .exp-company-full {
    font-size: 0.8rem;
    color: var(--white-icon);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .exp-period {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sec);
  }

  .exp-period-icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.9;
  }

  .exp-description {
    color: var(--white-icon);
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 768px) {
    .exp-description {
      font-size: 1rem;
    }
  }

  .exp-highlights {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 1rem 1.1rem;
    border-radius: 0.875rem;
    background: #ffffff05;
    border: 1px solid #ffffff08;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .exp-highlights li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.875rem;
    color: var(--white);
    line-height: 1.5;
  }

  .exp-highlight-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    margin-top: 0.45rem;
    border-radius: 50%;
    background: var(--sec);
    box-shadow: 0 0 8px var(--glow);
  }

  .exp-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .exp-tech-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.75rem;
    color: var(--white-icon);
    background: #ffffff08;
    border: 1px solid #ffffff10;
    border-radius: 0.5rem;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .exp-card:hover .exp-tech-tag {
    border-color: color-mix(in srgb, var(--sec) 25%, transparent);
  }

  .exp-tech-tag:hover {
    color: var(--white);
    background: color-mix(in srgb, var(--sec) 12%, transparent);
    border-color: color-mix(in srgb, var(--sec) 35%, transparent);
  }
</style>
