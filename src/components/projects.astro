---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import movelo from "../../public/movelo.png";
import PID from "../../public/PID.png";
import portal from "../../public/portal.png";
import meeting from "../../public/meeting.png";
import type { ImageMetadata } from "astro";

type ProjectStatus = "deployed" | "production" | "private";

interface Project {
  title: string;
  subtitle?: string;
  image: ImageMetadata;
  imageAlt: string;
  link: string;
  preview?: string;
  status: ProjectStatus;
  description: string;
  tags: string[];
  metrics?: string;
}

const statusStyles: Record<
  ProjectStatus,
  { label: string; class: string }
> = {
  deployed: {
    label: "Deployed",
    class: "bg-emerald-500/20 text-emerald-300 border-emerald-500/30",
  },
  production: {
    label: "In production",
    class: "bg-amber-500/20 text-amber-200 border-amber-500/30",
  },
  private: {
    label: "Private system",
    class: "bg-[#ffffff10] text-[var(--white-icon)] border-[#ffffff18]",
  },
};

const projects: Project[] = [
  {
    title: "PID",
    subtitle: "Decarbonization platform",
    image: PID as ImageMetadata,
    imageAlt: "PID decarbonization platform dashboard with maps and charts",
    link: "https://github.com/JuniorReisx/PID---Frontend",
    preview: "https://hackathon-bice-six-49.vercel.app/",
    status: "deployed",
    description:
      "Smart maps, dashboards, and gamification on Brazil’s energy transition, with AI-assisted insights.",
    tags: [
      "React",
      "Vite",
      "Tailwind",
      "MapLibre GL",
      "Recharts",
      "Node.js",
      "Express",
    ],
    metrics: "Live demo",
  },
  {
    title: "Portal SIHS",
    subtitle: "Systems intranet",
    image: portal as ImageMetadata,
    imageAlt: "SIHS unified systems portal home screen",
    link: "https://github.com/JuniorReisx/Portal---Intranet",
    preview: "https://sihs-intranet.vercel.app/",
    status: "deployed",
    description:
      "Centralized access to SIHS digital services with dynamic navigation and a responsive React and TypeScript UI.",
    tags: ["React", "TypeScript", "Vite", "Tailwind", "React Router"],
    metrics: "Live demo",
  },
  {
    title: "Movelo",
    subtitle: "Fleet & logistics",
    image: movelo as ImageMetadata,
    imageAlt: "Movelo fleet and logistics management dashboard",
    link: "https://github.com/JuniorReisx/Movelo",
    status: "private",
    description:
      "Internal platform with role-based access, real-time tracking, and operational dashboards.",
    tags: ["React", "TypeScript", "Node.js", "PostgreSQL"],
    metrics: "Enterprise",
  },
  {
    title: "Meeting System",
    subtitle: "SIHS scheduling",
    image: meeting as ImageMetadata,
    imageAlt: "SIHS meeting room booking system interface",
    link: "https://github.com/JuniorReisx/SIHS-meeting",
    status: "production",
    description:
      "Room booking with LDAP authentication, admin workflows, and integration with government infrastructure.",
    tags: ["React", "Express", "LDAP", "PostgreSQL"],
    metrics: "SIHS · Gov",
  },
];
---

<section
  id="projects"
  class="py-20 md:py-28 border-t border-[#ffffff08] text-[var(--white)]"
  aria-label="Featured projects"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-0">
    <SectionHeader
      eyebrow="Portfolio"
      title="Projects that prove the craft"
      description="Production systems at SIHS, private enterprise tools, and public demos — clear scope and stack on every card."
    />

    <ul class="projects-grid" role="list">
      {
        projects.map((project, i) => {
          const status = statusStyles[project.status];
          return (
            <li>
              <article
                class="reveal-on-scroll project-card group"
                style={`transition-delay: ${i * 0.05}s`}
              >
                <div class="project-thumb">
                  <Image
                    src={project.image}
                    alt={project.imageAlt}
                    width={320}
                    height={180}
                    loading="lazy"
                    class="project-thumb-img"
                  />
                  <div class="project-thumb-overlay" aria-hidden="true" />
                  {project.metrics && (
                    <span class="project-metric">{project.metrics}</span>
                  )}
                  <span class={`project-status ${status.class}`}>
                    {status.label}
                  </span>
                </div>

                <div class="project-body">
                  <header class="project-header">
                    <h3 class="project-title">{project.title}</h3>
                    {project.subtitle && (
                      <p class="project-subtitle">{project.subtitle}</p>
                    )}
                  </header>

                  <p class="project-desc">{project.description}</p>

                  <ul class="project-tags" role="list">
                    {project.tags.map((tag) => (
                      <li>
                        <span class="project-tag">{tag}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="project-actions">
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link"
                      aria-label={`${project.title} source code on GitHub`}
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="size-4 shrink-0"
                        aria-hidden="true"
                      >
                        <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
                      </svg>
                      GitHub
                    </a>
                    {project.preview ? (
                      <a
                        href={project.preview}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-preview btn-primary"
                        aria-label={`Live preview of ${project.title}`}
                      >
                        Live preview
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          class="size-3.5 shrink-0"
                          aria-hidden="true"
                        >
                          <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                        </svg>
                      </a>
                    ) : (
                      <span class="project-private-note">
                        Preview on request (private)
                      </span>
                    )}
                  </div>
                </div>
              </article>
            </li>
          );
        })
      }
    </ul>

    <a
      href="https://github.com/JuniorReisx?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="reveal-on-scroll projects-github-cta group"
      aria-label="Explore all repositories on GitHub"
    >
      <span>Explore all repositories on GitHub</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="size-5 group-hover:translate-x-0.5 transition-transform"
        aria-hidden="true"
      >
        <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
      </svg>
    </a>
  </div>
</section>

<style>
  .projects-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 640px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid #ffffff10;
    background: linear-gradient(145deg, #ffffff0a 0%, #ffffff02 100%);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: rgba(164, 118, 255, 0.28);
    box-shadow: 0 8px 32px rgba(164, 118, 255, 0.07);
    transform: translateY(-2px);
  }

  .project-thumb {
    position: relative;
    flex-shrink: 0;
    height: 7.5rem;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .project-thumb {
      height: 6.75rem;
    }
  }

  .project-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-thumb-img {
    transform: scale(1.04);
  }

  .project-thumb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--background) 0%,
      transparent 55%
    );
    pointer-events: none;
  }

  .project-metric,
  .project-status {
    position: absolute;
    top: 0.5rem;
    z-index: 1;
    padding: 0.2rem 0.5rem;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border-radius: 9999px;
    border: 1px solid transparent;
    line-height: 1.2;
  }

  .project-metric {
    left: 0.5rem;
    background: #14141acc;
    backdrop-filter: blur(8px);
    color: var(--sec);
    border-color: #ffffff14;
  }

  .project-status {
    right: 0.5rem;
  }

  .project-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 0.875rem 1rem 1rem;
    min-width: 0;
  }

  .project-header {
    margin-bottom: 0.35rem;
  }

  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.25;
    transition: color 0.25s ease;
  }

  .project-card:hover .project-title {
    color: var(--sec);
  }

  .project-subtitle {
    margin-top: 0.125rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--white-icon);
    line-height: 1.3;
  }

  .project-desc {
    font-size: 0.75rem;
    line-height: 1.45;
    color: var(--white-icon);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .project-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.625rem;
  }

  .project-tag {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--white-icon);
    background: #ffffff08;
    border: 1px solid #ffffff0e;
    border-radius: 0.25rem;
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding-top: 0.625rem;
    border-top: 1px solid #ffffff08;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--white);
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: var(--sec);
  }

  .project-preview {
    display: inline-flex !important;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem !important;
    font-size: 0.6875rem !important;
    margin-left: auto;
  }

  .project-private-note {
    margin-left: auto;
    font-size: 0.6875rem;
    font-style: italic;
    color: var(--white-icon);
  }

  .projects-github-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.875rem;
    border: 1px solid #ffffff12;
    background: #ffffff06;
    color: var(--white);
    transition:
      border-color 0.3s ease,
      color 0.3s ease;
  }

  .projects-github-cta:hover {
    border-color: color-mix(in srgb, var(--sec) 40%, transparent);
    color: var(--sec);
  }
</style>
