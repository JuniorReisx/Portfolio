---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import movelo from "../../public/movelo.png";
import rickandmorty from "../../public/rickandmorty.png";
import spongegame from "../../public/spongegame.png";
import meeting from "../../public/meeting.png";
import type { ImageMetadata } from "astro";

interface Project {
  title: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  status: "Deployed" | "Private System" | "In Production";
  description: string;
  tags: string[];
  featured?: boolean;
  metrics?: string;
}

const projects: Project[] = [
  {
    title: "Movelo",
    image: movelo as ImageMetadata,
    link: "https://github.com/JuniorReisx/Movelo",
    preview: "",
    status: "Private System",
    description:
      "Fleet and logistics management platform with role-based access, real-time tracking, and operational dashboards for internal teams.",
    tags: ["React", "TypeScript", "Node.js", "PostgreSQL"],
    featured: true,
    metrics: "Enterprise · Internal",
  },
  {
    title: "Meeting System",
    image: meeting as ImageMetadata,
    link: "https://github.com/JuniorReisx/SIHS-meeting",
    preview: "",
    status: "In Production",
    description:
      "Full-stack meeting scheduler built for SIHS — room booking, LDAP auth, and admin workflows integrated with government infrastructure.",
    tags: ["React", "Express", "LDAP", "PostgreSQL"],
    featured: true,
    metrics: "SIHS · Gov",
  },
  {
    title: "Rick and Morty Explorer",
    image: rickandmorty as ImageMetadata,
    link: "https://github.com/JuniorReisx/Rick-and-Morty-Front-End",
    preview: "https://rickandmorty-eosin-five.vercel.app/",
    status: "Deployed",
    description:
      "Character explorer consuming the public API — filters, pagination, and responsive UI deployed on Vercel.",
    tags: ["React", "REST API", "Vercel"],
    metrics: "Live demo",
  },
  {
    title: "Sponge Game",
    image: spongegame as ImageMetadata,
    link: "https://github.com/JuniorReisx/Sponge-Game",
    preview: "https://bob-esponja-rl.vercel.app/",
    status: "Deployed",
    description:
      "Interactive browser game with animations and score mechanics — showcases creative front-end and game-loop logic.",
    tags: ["JavaScript", "Canvas", "Vercel"],
    metrics: "Live demo",
  },
];
---

<section id="projects" class="py-20 md:py-28 border-t border-[#ffffff08] text-[var(--white)]">
  <div class="max-w-5xl mx-auto">
    <SectionHeader
      eyebrow="Portfolio"
      title="Projects that prove the craft"
      description="A mix of production systems at SIHS, private enterprise tools, and public demos — each with clear scope and stack."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project, i) => (
          <article
            class={`reveal-on-scroll project-card group relative overflow-hidden rounded-2xl border border-[#ffffff10] bg-gradient-to-br from-[#ffffff08] to-transparent ${
              project.featured ? "md:col-span-2" : ""
            }`}
            style={`transition-delay: ${i * 0.06}s`}
          >
            <div class={`relative overflow-hidden ${project.featured ? "h-56 md:h-72" : "h-48"}`}>
              <Image
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--background)] via-[var(--background)]/40 to-transparent"></div>
              {project.metrics && (
                <span class="absolute top-4 left-4 px-3 py-1 text-xs font-semibold rounded-full glass-card text-[var(--sec)]">
                  {project.metrics}
                </span>
              )}
              <span
                class={`absolute top-4 right-4 px-3 py-1 text-xs font-medium rounded-full ${
                  project.status === "Deployed"
                    ? "bg-emerald-500/20 text-emerald-300 border border-emerald-500/30"
                    : "bg-[var(--sec)]/15 text-[var(--sec)] border border-[var(--sec)]/25"
                }`}
              >
                {project.status}
              </span>
            </div>

            <div class="p-6 md:p-8">
              <h3 class="text-2xl md:text-3xl font-bold text-[var(--white)] group-hover:text-[var(--sec)] transition-colors">
                {project.title}
              </h3>
              <p class="mt-3 text-[var(--white-icon)] leading-relaxed">{project.description}</p>

              <div class="flex flex-wrap gap-2 mt-4">
                {project.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-[#ffffff08] text-[var(--white-icon)] border border-[#ffffff10]">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="flex flex-wrap gap-3 mt-6 pt-6 border-t border-[#ffffff08]">
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--white)] hover:text-[var(--sec)] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
                    <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"/>
                  </svg>
                  Source code
                </a>
                {project.preview ? (
                  <a
                    href={project.preview}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-primary !py-2 !px-4 !text-sm"
                  >
                    Live preview
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4">
                      <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/>
                    </svg>
                  </a>
                ) : (
                  <span class="text-sm text-[var(--white-icon)] italic self-center">Preview on request (private)</span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <a
      href="https://github.com/JuniorReisx?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
      class="reveal-on-scroll mt-10 w-full flex items-center justify-center gap-3 py-4 rounded-2xl glass-card hover:border-[var(--sec)]/40 transition-all duration-300 group"
    >
      <span class="text-lg font-semibold group-hover:text-[var(--sec)] transition-colors">Explore all repositories on GitHub</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6 group-hover:translate-x-1 transition-transform">
        <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .project-card:hover {
    border-color: rgba(164, 118, 255, 0.25);
    box-shadow: 0 0 40px rgba(164, 118, 255, 0.08);
  }
</style>
