---
import LetterGlitch from "../React/LetterGlitch.tsx";
import LogoWall from "../components/logoWall.astro";
import SkillsList from "../React/SkillsList.tsx";

const roles = [
  "Fullstack Developer",
  "Spring Boot Engineer",
  "React & TypeScript Specialist",
  "DevOps-minded Builder",
];
---

<section class="text-[var(--white)] mt-12 md:mt-0 relative" id="home">
  <div class="max-w-5xl mx-auto space-y-10 md:py-32 pb-16">
    <!-- Status pill -->
    <div class="hero-item hero-delay-1 flex flex-wrap items-center gap-3">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-card text-sm">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
        </span>
        <span class="text-[var(--white-icon)]">Open to</span>
        <span class="text-[var(--white)] font-medium">full-time & contract</span>
      </span>
      <span class="text-[var(--white-icon)] text-sm hidden sm:inline">·</span>
      <span class="text-[var(--white-icon)] text-sm hidden sm:inline">Salvador, Brazil · UTC-3</span>
    </div>

    <div class="text-left space-y-6">
      <p class="hero-item hero-delay-2 text-lg text-[var(--white-icon)]">
        Hi, I'm <span class="text-[var(--white)] font-semibold">Junior Reis</span>
      </p>

      <div class="flex flex-col gap-8">
        <div class="hero-item hero-delay-3 space-y-4">
          <h1 class="text-[var(--white)] text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold leading-[0.95] tracking-tight">
            I turn complex problems into
            <span class="shiny-sec block mt-2">elegant software.</span>
          </h1>

          <p class="text-xl md:text-2xl text-[var(--white-icon)] max-w-2xl leading-relaxed font-normal" style="font-family: 'DM Sans', sans-serif;">
            Fullstack developer focused on
            <span class="text-[var(--white)]">production-grade APIs</span>,
            Spring Boot backends, and interfaces recruiters (and users) actually remember.
          </p>

          <!-- Rotating role -->
          <div class="flex items-center gap-3 text-lg md:text-xl">
            <span class="text-[var(--white-icon)]">Currently crafting as</span>
            <span
              id="role-rotate"
              class="text-[var(--sec)] font-semibold min-w-[12ch] inline-block"
              data-roles={JSON.stringify(roles)}
            >
              {roles[0]}
            </span>
          </div>
        </div>

        <!-- CTAs -->
        <div class="hero-item hero-delay-4 flex flex-wrap gap-4">
          <a href="#projects" class="btn-primary">
            View selected work
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
              <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/>
            </svg>
          </a>
          <a href="#contact" class="btn-secondary">
            Let's talk hiring
          </a>
          <a
            href="mailto:gilmaikjunior2@gmail.com?subject=Opportunity%20%E2%80%94%20Junior%20Reis"
            class="btn-secondary hidden sm:inline-flex"
          >
            gilmaikjunior2@gmail.com
          </a>
        </div>

        <!-- Value props for recruiters -->
        <div class="hero-item hero-delay-5 grid sm:grid-cols-3 gap-4 pt-2">
          {
            [
              { icon: "⚡", title: "Ship fast", desc: "From MVP to production with CI/CD and clean architecture." },
              { icon: "🏛", title: "Gov & enterprise", desc: "SIHS internal systems — LDAP, PostgreSQL, Windows Server." },
              { icon: "🎯", title: "Full ownership", desc: "Backend, frontend, infra basics — one engineer, end-to-end." },
            ].map((item) => (
              <div class="glass-card rounded-2xl p-5 hover:border-[var(--sec)]/25 transition-colors duration-300">
                <span class="text-2xl">{item.icon}</span>
                <h3 class="mt-3 font-semibold text-[var(--white)] text-base">{item.title}</h3>
                <p class="mt-1 text-sm text-[var(--white-icon)] leading-relaxed">{item.desc}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Social -->
      <div class="hero-item hero-delay-6 flex flex-wrap justify-start gap-3 pt-2">
        <a
          target="_blank"
          href="https://github.com/JuniorReisx"
          aria-label="GitHub"
          class="social-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
            <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z"/>
          </svg>
        </a>
        <a
          target="_blank"
          href="https://www.linkedin.com/in/gil-maik-junior/"
          aria-label="LinkedIn"
          class="social-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
            <path d="M18.3362 18.339H15.6707V14.1622C15.6707 13.1662 15.6505 11.8845 14.2817 11.8845C12.892 11.8845 12.6797 12.9683 12.6797 14.0887V18.339H10.0142V9.75H12.5747V10.9207H12.6092C12.967 10.2457 13.837 9.53325 15.1367 9.53325C17.8375 9.53325 18.337 11.3108 18.337 13.6245V18.339H18.3362ZM7.00373 8.57475C6.14573 8.57475 5.45648 7.88025 5.45648 7.026C5.45648 6.1725 6.14648 5.47875 7.00373 5.47875C7.85873 5.47875 8.55173 6.1725 8.55173 7.026C8.55173 7.88025 7.85798 8.57475 7.00373 8.57475ZM8.34023 18.339H5.66723V9.75H8.34023V18.339ZM19.6697 3H4.32923C3.59498 3 3.00098 3.5805 3.00098 4.29675V19.7033C3.00098 20.4202 3.59498 21 4.32923 21H19.6675C20.401 21 21.001 20.4202 21.001 19.7033V4.29675C21.001 3.5805 20.401 3 19.6675 3H19.6697Z"/>
          </svg>
        </a>
        <a
          target="_blank"
          href="mailto:gilmaikjunior2@gmail.com"
          aria-label="Email"
          class="social-btn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-7">
            <path d="m18.73 5.41l-1.28 1L12 10.46L6.55 6.37l-1.28-1A2 2 0 0 0 2 7.05v11.59A1.36 1.36 0 0 0 3.36 20h3.19v-7.72L12 16.37l5.45-4.09V20h3.19A1.36 1.36 0 0 0 22 18.64V7.05a2 2 0 0 0-3.27-1.64"/>
          </svg>
        </a>
        <a href="/cv.pdf" download aria-label="Download CV" class="social-btn flex items-center gap-2 px-5 text-sm font-semibold">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5">
            <path d="M3 19H21V21H3V19ZM13 13.1716L19.0711 7.1005L20.4853 8.51472L12 17L3.51472 8.51472L4.92893 7.1005L11 13.1716V2H13V13.1716Z"/>
          </svg>
          Download CV
        </a>
      </div>
    </div>

    <div class="hero-item hero-delay-7">
      <p class="text-xs uppercase tracking-widest text-[var(--white-icon)] mb-4">Stack I work with daily</p>
      <LogoWall />
    </div>

    <div class="hero-item hero-delay-8 flex flex-col lg:flex-row items-start gap-10 lg:gap-16">
      <SkillsList client:load />
      <div class="flex justify-center w-full lg:w-auto lg:shrink-0 md:h-[320px] h-[280px] pt-4 lg:pt-6">
        <div class="relative w-[290px] h-full">
          <div class="absolute inset-0 rounded-2xl bg-[var(--sec)]/10 blur-3xl"></div>
          <LetterGlitch
            client:load
            glitchColors={["#5e4491", "#A476FF", "#241a38"]}
            glitchSpeed={33}
            centerVignette={false}
            outerVignette={true}
            smooth={true}
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const roleEl = document.getElementById("role-rotate");
  if (roleEl) {
    const roles: string[] = JSON.parse(roleEl.dataset.roles || "[]");
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % roles.length;
      roleEl.style.opacity = "0";
      roleEl.style.transform = "translateY(8px)";
      setTimeout(() => {
        roleEl.textContent = roles[idx];
        roleEl.style.opacity = "1";
        roleEl.style.transform = "translateY(0)";
      }, 200);
    }, 3200);
    roleEl.style.transition = "opacity 0.2s, transform 0.2s";
  }
</script>

<style>
  .hero-item {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .hero-delay-1 { animation-delay: 0.05s; }
  .hero-delay-2 { animation-delay: 0.12s; }
  .hero-delay-3 { animation-delay: 0.22s; }
  .hero-delay-4 { animation-delay: 0.34s; }
  .hero-delay-5 { animation-delay: 0.44s; }
  .hero-delay-6 { animation-delay: 0.54s; }
  .hero-delay-7 { animation-delay: 0.64s; }
  .hero-delay-8 { animation-delay: 0.74s; }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .social-btn {
    color: var(--white-icon);
    transition: all 0.3s ease;
    border: 1px solid var(--white-icon-tr);
    padding: 0.75rem;
    border-radius: 0.875rem;
    background: #1414149c;
  }

  .social-btn:hover {
    color: var(--white);
    background: var(--white-icon-tr);
    border-color: var(--sec);
  }
</style>
